# IP que se mostrará en el QR.
# Si está vacía, se detecta automáticamente.
# En WSL hay que ponerla manualmente con la IP de Windows en la WiFi
# (ejecutar `ipconfig` en PowerShell y buscar el adaptador Wi-Fi).
IP_OVERRIDE=192.168.1.10

# Duración del timer por dilema en segundos.
DILEMA_DURACION=30

# OBSOLETO: la pantalla de resultados ahora avanza manualmente (ESPACIO o botón presentador).
# RESULTADOS_DURACION=15

# URL pública completa (para ngrok o despliegues remotos).
# Si está vacía, se construye con IP_OVERRIDE + puerto.
# Ejemplo: URL_OVERRIDE=https://parched-humbly-marbles.ngrok-free.dev
URL_OVERRIDE=https://parched-humbly-marbles.ngrok-free.dev
